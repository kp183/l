# =============================================================================
# AgentLens MVP — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# PostgreSQL connection string using the asyncpg driver.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agentlens:agentlens@postgres:5432/agentlens

# -----------------------------------------------------------------------------
# Redis
# Redis connection URL used for API key caching (TTL 300s) and WebSocket pub/sub.
# Format: redis://<host>:<port>/<db>
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Clerk — Backend Secret Key
# Secret key for server-side Clerk API calls (e.g. user management).
# Obtain from: Clerk Dashboard → API Keys → Secret keys
# Keep this value strictly server-side; never expose it to the browser.
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Clerk — Publishable Key
# Public key used by the backend to identify your Clerk application.
# Obtain from: Clerk Dashboard → API Keys → Publishable key
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_bWFya2V0aW5nLWFwcC0xMC5jbGVyay5hY2NvdW50cy5kZXYk

# -----------------------------------------------------------------------------
# Clerk — JWKS Endpoint
# URL of the Clerk JSON Web Key Set used to verify JWT signatures.
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
# Obtain from: Clerk Dashboard → API Keys → Frontend API URL
# -----------------------------------------------------------------------------
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# -----------------------------------------------------------------------------
# Clerk — Next.js Publishable Key (browser-safe)
# Same publishable key exposed to the Next.js frontend via NEXT_PUBLIC_ prefix.
# Must match CLERK_PUBLISHABLE_KEY above.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_bWFya2V0aW5nLWFwcC0xMC5jbGVyay5hY2NvdW50cy5kZXYk

# -----------------------------------------------------------------------------
# CORS Origins
# Comma-separated list of allowed origins for cross-origin requests.
# Wildcards (*) are NOT permitted — use an explicit allowlist.
# Example for local development: http://localhost:3000
# Example for production: https://app.agentlens.dev,https://www.agentlens.dev
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Environment
# Runtime environment identifier. Controls auto-migration on startup and
# other environment-specific behaviour.
# Allowed values: development | production
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# API Version
# Version string returned by the /health endpoint and used in API routing.
# Default: v1
# -----------------------------------------------------------------------------
API_VERSION=v1

# -----------------------------------------------------------------------------
# Ingest Rate Limit
# Maximum number of POST /v1/ingest requests allowed per API key per minute.
# Requests exceeding this limit receive a 429 response with a Retry-After header.
# Default: 1000
# -----------------------------------------------------------------------------
INGEST_RATE_LIMIT=1000
